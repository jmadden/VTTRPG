# ── Configuration ─────────────────────────────────────────────────────────
# Copy this to `.env` and adjust. The same file backs local dev, the local
# prod-parity run (`npm run serve`), and documents what Render needs.

# PostgreSQL connection string. Local dev uses a local database; in the cloud
# this is the managed Postgres URL (set in the Render dashboard, not here).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vtt

# Set to 1 for managed cloud Postgres that requires SSL (e.g. Render external
# connections). Leave unset/empty for local Postgres.
# DATABASE_SSL=1

# Backend HTTP + Socket.io port. Render provides PORT automatically.
PORT=4000

# Where map image assets are stored/served from (relative to backend/).
ASSET_DIR=./uploads

# Comma-separated origins allowed for cross-origin Socket.io (dev only). Not
# needed in production, where the backend serves the SPA same-origin.
# Example: http://localhost:5173,https://xxxx.ngrok-free.app
CORS_ORIGINS=http://localhost:5173

# Set to 1 to make the backend serve the built frontend (frontend/dist) on its
# own origin. `npm start` / `npm run serve` and Render set this; leave unset for
# `npm run dev` (Vite serves the frontend on :5173).
# SERVE_CLIENT=1

# ── Frontend (Vite) ───────────────────────────────────────────────────────
# URL the browser uses to reach the backend. Leave EMPTY for same-origin (the
# production build and the local prod-parity run). Dev falls back to
# http://localhost:4000 automatically. Set it only to point at a specific
# backend (e.g. an ngrok URL during dev).
VITE_SERVER_URL=
