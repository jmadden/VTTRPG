# ── Local Host configuration ──────────────────────────────────────────────
# The whole stack runs on the GM's machine. Copy this to `.env` and adjust.

# PostgreSQL connection string (local database).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vtt

# Backend HTTP + Socket.io port.
PORT=4000

# Where map image assets are stored/served from (relative to backend/).
ASSET_DIR=./uploads

# Comma-separated origins allowed to connect (LAN IP, ngrok URL, localhost).
# Example: http://localhost:5173,http://192.168.1.20:5173,https://xxxx.ngrok-free.app
CORS_ORIGINS=http://localhost:5173

# ── Frontend (Vite) ───────────────────────────────────────────────────────
# URL the browser uses to reach the backend Socket.io/HTTP server.
# On a player's machine this is the GM's LAN IP or the ngrok tunnel.
VITE_SERVER_URL=http://localhost:4000
