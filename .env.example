# ── Configuration ─────────────────────────────────────────────────────────
# Copy this to `.env` and adjust. The single root `.env` backs local dev, the
# local prod-parity run (`npm run serve`), and the Docker stack (docker compose
# reads this file). See docs/10 for the Docker + DigitalOcean deployment guide.

# ── App runtime (backend) ───────────────────────────────────────────────────

# PostgreSQL connection string used by `npm run dev` / `npm run serve`.
# In the Docker stack the app's DATABASE_URL is set by docker-compose (pointing
# at the postgres-db service), so you do NOT set it for the container.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vtt

# Set to 1 only for a managed Postgres that requires SSL (e.g. a DigitalOcean
# Managed Database). The in-network Dockerized Postgres does NOT need it.
# DATABASE_SSL=1

# Backend HTTP + Socket.io port.
PORT=4000

# Where map image assets are stored/served from (relative to backend/ in dev;
# an absolute /app/uploads volume in the Docker stack).
ASSET_DIR=./uploads

# Comma-separated origins allowed for cross-origin Socket.io (dev only). Not
# needed in production, where the backend serves the SPA same-origin behind Caddy.
CORS_ORIGINS=http://localhost:5173

# Set to 1 to make the backend serve the built frontend (frontend/dist) on its
# own origin. `npm start` / `npm run serve` and the Docker image set this; leave
# unset for `npm run dev` (Vite serves the frontend on :5173).
# SERVE_CLIENT=1

# ── Frontend (Vite, build-time) ─────────────────────────────────────────────
# URL the browser uses to reach the backend. Leave EMPTY for same-origin (the
# production/Docker build and the local prod-parity run). Dev falls back to
# http://localhost:4000 automatically. It is baked at build time, so it MUST be
# empty when building the Docker image (the .dockerignore keeps this file out).
VITE_SERVER_URL=

# ── Docker / deployment (docker compose reads these) ────────────────────────
# Credentials for the Dockerized Postgres service and the database name.
POSTGRES_USER=vtt
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=vtt

# App port publish binding. Loopback by default (localhost and host-run tunnels
# like ngrok/Tailscale reach it, but it is not exposed on a droplet's public
# interface). Set to 0.0.0.0 for direct LAN play.
# APP_BIND=127.0.0.1

# Caddy site address. ONLY used in the DigitalOcean / edge mode
# (`npm run deploy:cloud`). Set your domain or a free duckdns subdomain (e.g.
# vtt.example.com) and Caddy provisions HTTPS automatically via Let's Encrypt.
# Ignored by the local and tunnel modes.
SITE_ADDRESS=:80
